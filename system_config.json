{
  "system": {
    "mode": "live",
    "description": "System operation mode: 'live' or 'offline'"
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file_logging": true,
    "log_directory": "logs",
    "max_log_files": 10,
    "max_log_size_mb": 50,
    "console_logging": true
  },
  "event_bus": {
    "max_event_history": 10000,
    "enable_event_logging": true,
    "thread_pool_size": 4,
    "event_timeout_seconds": 30,
    "dead_letter_queue": true
  },
  "threading": {
    "max_worker_threads": 8,
    "thread_timeout_seconds": 60,
    "daemon_threads": true,
    "thread_name_prefix": "VWAP",
    "event_bus_workers": 2,
    "streamer_workers": 4,
    "strategy_workers": 2,
    "executor_workers": 2,
    "system_workers": 2
  },
  "streamer": {
    "type": "binance",
    "async_enabled": true,
    "config": {
      "offline": {
        "data_dir": "data",
        "playback_speed": 1.0,
        "tick_interval": 1.0,
        "base_price": 18500.0,
        "async_mode": true
      },
      "binance": {
        "reconnect_attempts": 5,
        "reconnect_delay": 2.0,
        "stream_timeout": 60,
        "testnet": false,
        "name_symbol": "btcusdt"
      }
    }
  },
  "executor": {
    "type": "mock",
    "config": {
      "mock": {
        "slippage_factor": 0.0001,
        "execution_delay": 0.1,
        "initial_cash": 100000.0
      },
      "binance": {
        "order_type": "MARKET",
        "time_in_force": "GTC",
        "test_mode": true,
        "recv_window": 5000,
        "timeout": 30,
        "max_retries": 3
      }
    }
  },
  "performance": {
    "enable_profiling": false,
    "memory_monitoring": false,
    "performance_logging_interval": 300,
    "gc_collection_interval": 600
  },
  "data_storage": {
    "sqlite_path": "data/market_data.db",
    "backup_enabled": true,
    "backup_interval_hours": 24,
    "data_retention_days": 30,
    "compression_enabled": true
  },
  "network": {
    "connection_timeout": 10,
    "read_timeout": 30,
    "max_retries": 3,
    "retry_delay": 1.0,
    "keepalive": true
  },
  "monitoring": {
    "health_check_interval": 60,
    "metrics_collection": true,
    "alert_thresholds": {
      "memory_usage_percent": 80,
      "cpu_usage_percent": 90,
      "event_queue_size": 1000,
      "error_rate_per_minute": 10
    }
  },
  "security": {
    "encrypt_logs": false,
    "api_rate_limiting": true,
    "max_requests_per_second": 10,
    "enable_audit_logging": true
  },
  "development": {
    "debug_mode": false,
    "mock_data": false,
    "test_mode": false,
    "verbose_error_messages": true,
    "enable_hot_reload": true
  },
  "cli": {
    "dashboard_refresh_rate": 1.0,
    "max_display_rows": 50,
    "color_output": true,
    "auto_scroll": true,
    "save_session": true
  },
  "candle_maker": {
    "default_timeframe": "5min",
    "max_candles_memory": 1000,
    "persist_candles": true,
    "validate_ohlc": true,
    "calculate_vwap": true
  },
  "streamers": {
    "reconnect_attempts": 5,
    "reconnect_delay": 2.0,
    "heartbeat_interval": 30,
    "buffer_size": 1024,
    "enable_compression": false
  },
  "trading_session": {
    "market_hours": {
      "start_time": "09:15",
      "end_time": "15:30",
      "timezone": "Asia/Kolkata"
    },
    "pre_market_data": false,
    "after_hours_trading": false,
    "weekend_mode": "disabled",
    "holiday_check": true
  },
  "data_sources": {
    "primary_streamer": "offline",
    "backup_streamers": ["zerodha"],
    "data_redundancy": false,
    "cross_validation": false,
    "price_tolerance_percent": 0.1
  }
}
